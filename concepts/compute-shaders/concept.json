  "domain": "hardware",
  "family": "GPU",
  "def": "General-purpose programs run on the GPU outside the graphics pipeline, over thread groups.",
  "problem": "Run massively-parallel non-graphics compute on the GPU from graphics or compute APIs.",
  "mechanism": "Kernels execute over a grid of work-groups; threads share fast group-local memory and synchronise within a group; the API dispatches and manages buffers.",
  "benefits": [
    "Massive parallel throughput",
    "Shared local memory for cooperation",
    "Integrates with rendering pipelines"
  ],
  "limits": [
    "Host/device data transfer cost",
    "Divergence and occupancy tuning",
    "API/portability fragmentation"
  ],
  "failures": [
    "Group-shared memory race/sync bugs",
    "Poor occupancy from register/LDS pressure"
  ],
  "whenNot": [
    "Small/irregular/latency-critical tasks"
  ],
  "myths": [
    "\"Compute shaders are only for graphics\" — used for physics, ML, simulation, crypto"
  ],
