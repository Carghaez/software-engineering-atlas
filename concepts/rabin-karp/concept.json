    "Hash collisions force verification",
    "Worst case O(nm) with bad hashing",
    "Modulus/overflow care"
  ],
  "failures": [
    "Weak hash → many collisions / DoS",
    "Forgetting to verify on hash match"
  ],
  "whenNot": [
    "Single small pattern (KMP/Boyer-Moore simpler)"
  ],
  "myths": [
    "\"Hash match means string match\" — must verify; collisions happen"
  ],
