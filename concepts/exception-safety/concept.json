  "id": "exception-safety",
  "name": "Exception Safety",
  "type": "Defensive-programming practice",
  "secondary": [
    "Error-handling technique"
  ],
  "domain": "reliability",
  "family": "Error policy",
  "def": "Guarantees about program state when an operation is interrupted by an exception.",
  "problem": "Ensure that a failure mid-operation does not leak resources or leave invariants broken.",
  "mechanism": "Tiers of guarantee — no-throw, strong (commit-or-rollback), basic (valid but unspecified state); achieved via RAII, copy-and-swap and careful ordering.",
  "benefits": [
    "Leak-free, invariant-preserving failures",
    "Predictable rollback semantics",
    "Composability under errors"
  ],
  "limits": [
    "Strong guarantee can cost copies",
    "Reasoning burden; subtle",
    "Mixed error-model code is hard"
  ],
  "failures": [
    "Throwing from destructors / cleanup",
    "Half-updated state on the basic guarantee"
  ],
  "whenNot": [
    "Languages/styles using error returns instead of exceptions"
  ],
  "myths": [
    "\"Exceptions automatically clean up\" — only RAII/finally make that true"
  ],
  "use": "Direct",
  "sectors": [
    "Libraries",
    "Systems",
    "Anything with exceptions"
  ],
  "complexity": null,
