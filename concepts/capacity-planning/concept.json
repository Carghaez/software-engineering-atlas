  "id": "capacity-planning",
  "name": "Capacity Planning",
  "type": "Debugging or observability technique",
  "secondary": [
    "Reliability or resilience practice"
  ],
  "domain": "observability",
  "family": "Performance engineering",
  "def": "Forecasting resource needs to meet demand reliably and cost-effectively.",
  "problem": "Provision enough capacity for growth and peaks without overspending.",
  "mechanism": "Model demand from historical metrics and growth, relate it to resource use via load tests, and plan headroom, autoscaling and scaling limits.",
  "benefits": [
    "Avoids capacity-driven outages",
    "Controls cost (right-sizing)",
    "Informs autoscaling policy"
  ],
  "limits": [
    "Forecasts are uncertain",
    "Bursty/viral demand hard to predict",
    "Needs good historical data"
  ],
  "failures": [
    "Planning for averages, not peaks",
    "Hitting hard scaling limits unexpectedly"
  ],
  "whenNot": [
    "Trivial, low-traffic systems"
  ],
  "myths": [
    "\"Autoscaling removes the need to plan\" — limits, costs and cold capacity still need planning"
  ],
  "use": "Direct",
  "sectors": [
    "Cloud",
    "SRE",
    "Large-scale services"
  ],
