  "type": "Verification technique",
  "secondary": [
    "Testing technique"
  ],
  "domain": "testing",
  "family": "Program analysis",
  "def": "Analysing a program with symbolic (not concrete) inputs to explore many paths and find bugs.",
  "problem": "Discover inputs that trigger bugs or reach paths that random/example testing misses.",
  "mechanism": "Inputs are symbols; the engine tracks path constraints and uses an SMT solver to find inputs satisfying each path (and to detect assertion violations).",
  "benefits": [
    "Systematic path exploration",
    "Generates concrete bug-triggering inputs",
    "Finds deep edge cases"
  ],
  "limits": [
    "Path explosion",
    "Solver limits (loops, nonlinear, env)",
    "Slow; scaling is hard"
  ],
  "failures": [
    "Path explosion making it intractable",
    "Unmodelled environment/syscalls"
  ],
  "whenNot": [
    "Large messy systems without harnessing"
  ],
  "myths": [
    "\"Symbolic execution proves correctness\" — it explores paths; full proof is generally infeasible"
  ],
  "use": "Indirect",
