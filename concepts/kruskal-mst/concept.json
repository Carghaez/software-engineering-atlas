  "domain": "algos",
  "family": "Graph / optimisation",
  "def": "Finds a minimum-total-weight set of edges connecting all nodes of a weighted graph.",
  "problem": "Connect all nodes as cheaply as possible — network/grid/cluster design.",
  "mechanism": "Kruskal greedily adds the cheapest edge that does not form a cycle (using union-find); Prim grows a tree from a node via a priority queue.",
  "benefits": [
    "Provably optimal (greedy on a matroid)",
    "O(E log V)",
    "Two complementary strategies (sparse vs dense)"
  ],
  "limits": [
    "Undirected graphs only",
    "Ties give non-unique trees"
  ],
  "failures": [
    "Cycle check errors (Kruskal) producing invalid trees",
    "Wrong on directed graphs"
  ],
  "whenNot": [
    "Directed graphs (use arborescence algorithms)"
  ],
  "myths": [
    "\"Kruskal and Prim give different trees\" — both are optimal; weights tie-break the shape"
  ],
  "use": "Direct",
  "sectors": [
    "Network design",
    "Clustering",
    "Circuit layout"
  ],
