  "domain": "observability",
  "family": "Failure diagnostics",
  "def": "Automatically capturing diagnostic state when a program crashes for later analysis.",
  "problem": "Diagnose field crashes you cannot reproduce, with the context needed to fix them.",
  "mechanism": "On a fatal fault, capture a stack trace / core dump / minidump (plus breadcrumbs and metadata) and upload it to a service that symbolicates and aggregates by signature.",
  "benefits": [
    "Diagnose un-reproducible field crashes",
    "Aggregates by frequency/impact",
    "Symbolicated stacks speed fixes"
  ],
  "limits": [
    "PII in dumps (privacy)",
    "Symbol management for symbolication",
    "Dump size/upload cost"
  ],
  "failures": [
    "Missing debug symbols → unreadable stacks",
    "Leaking sensitive memory in dumps"
  ],
  "whenNot": [
    "Trivial local tools"
  ],
  "myths": [
    "\"Logs are enough for crashes\" — a core dump captures state logs never recorded"
  ],
  "use": "Indirect",
