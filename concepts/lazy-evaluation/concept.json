  "id": "lazy-evaluation",
  "name": "Lazy Evaluation",
  "type": "Functional abstraction",
  "secondary": [
    "Performance-optimisation technique"
  ],
  "domain": "fp",
  "family": "Evaluation strategy",
  "def": "Defers computing a value until it is actually needed, and memoises the result.",
  "problem": "Avoid wasted work and enable infinite/large structures by computing on demand.",
  "mechanism": "Expressions become thunks evaluated on first use; results cached. Enables infinite sequences and short-circuiting.",
  "benefits": [
    "Skips unneeded work",
    "Infinite/streaming sequences",
    "Decouples definition from consumption"
  ],
  "limits": [
    "Space leaks from retained thunks",
    "Unpredictable timing of evaluation/effects",
    "Debugging when-it-runs is hard"
  ],
  "failures": [
    "Thunk build-up → memory blow-up",
    "Effects firing at surprising times"
  ],
  "whenNot": [
    "Strict, predictable timing required",
    "Effectful code where order matters"
  ],
  "myths": [
    "\"Lazy is always faster\" — thunk overhead can lose for always-needed values"
  ],
  "use": "Both",
  "sectors": [
    "Data pipelines",
    "Functional langs",
    "Iterators/streams"
  ],
