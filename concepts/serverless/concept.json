    "Fast event-driven glue"
  ],
  "limits": [
    "Cold-start latency",
    "Execution time/resource limits",
    "Vendor lock-in; statelessness constraints"
  ],
  "failures": [
    "Cold starts hurting latency SLOs",
    "Chatty function-to-function calls; cost surprises"
  ],
  "whenNot": [
