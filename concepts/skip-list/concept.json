  "family": "Probabilistic ordered",
  "def": "A layered linked list giving expected O(log n) ordered search via randomised express lanes.",
  "problem": "An ordered map with logarithmic operations that is far simpler to make lock-free than a balanced tree.",
  "mechanism": "Each node is promoted to higher levels with probability p; searches descend express lanes then drop down, halving the span at each level on average.",
  "benefits": [
    "Expected O(log n) without rotations",
    "Far simpler concurrent/lock-free implementation than trees",
    "Easy range queries"
  ],
  "limits": [
    "Probabilistic — rare bad layouts degrade performance",
    "Pointer-heavy, poor cache locality",
    "Higher memory overhead"
  ],
  "failures": [
    "Weak RNG → degenerate level distribution",
    "Worst case O(n) (unbounded but unlikely)"
  ],
  "whenNot": [
    "Tight cache/memory budgets",
    "Deterministic worst-case guarantees required"
  ],
  "myths": [
