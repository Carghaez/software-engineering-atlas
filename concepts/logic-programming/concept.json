  "def": "Programs as facts and rules; computation is automated logical inference / search for satisfying answers.",
  "problem": "Solve relational and combinatorial problems by stating constraints and letting a solver search.",
  "mechanism": "A resolution engine (e.g. Prolog) unifies goals against rules and backtracks; constraint logic adds domain solvers.",
  "benefits": [
    "Extremely concise for search/relational problems",
    "Bidirectional relations, automatic backtracking",
    "Declarative knowledge representation"
  ],
  "limits": [
    "Performance hard to predict/control",
    "Niche outside AI/verification",
    "Steep mental model for imperative devs"
  ],
  "failures": [
    "Non-terminating search from bad rule ordering",
    "Exponential blow-up without cuts/constraints"
  ],
  "whenNot": [
    "Performance-critical or stateful systems",
    "Teams lacking solver expertise"
  ],
  "myths": [
    "\"Dead paradigm\" — alive in Datalog, type checkers, and config analysis"
