  "def": "A first-in-first-out collection with enqueue at the back and dequeue at the front.",
  "problem": "Process items in arrival order: scheduling, buffering, breadth-first traversal, pipelines.",
  "mechanism": "Backed by a ring buffer or chunked deque for O(1) at both ends; concurrent variants add locking or lock-free coordination.",
  "benefits": [
    "O(1) enqueue/dequeue",
    "Models fair, in-order processing",
    "Foundation for producer/consumer"
  ],
  "limits": [
    "No random access",
    "Bounded queues need full-handling policy"
  ],
  "failures": [
    "Unbounded growth under backpressure",
    "Lost ordering with naive concurrent impls"
  ],
  "whenNot": [
    "Priority ordering needed (use a heap)",
    "LIFO semantics (use a stack)"
  ],
  "myths": [
    "\"Queues are inherently concurrent\" — the ADT is sequential; concurrency is an added concern"
