  "domain": "memory",
  "family": "Ownership transfer",
  "def": "Transferring ownership of a resource from one object to another instead of copying it.",
  "problem": "Avoid expensive deep copies when a value is being handed off rather than duplicated.",
  "mechanism": "A move leaves the source in a valid empty state and transfers the underlying buffer/handle to the destination, typically O(1).",
  "benefits": [
    "Eliminates deep-copy cost on transfer",
    "Enables non-copyable resources (unique ownership)",
    "Underpins efficient containers"
  ],
  "limits": [
    "Moved-from state pitfalls",
    "Subtle rules (C++); harder mental model",
    "Self-move edge cases"
  ],
  "failures": [
    "Using a moved-from object (use-after-move)",
    "Missing/incorrect move constructors"
  ],
  "whenNot": [
    "Cheap-to-copy values (trivial types)"
  ],
  "myths": [
    "\"Move is free\" — it is cheap, not zero; it still updates pointers/handles"
  ],
