  "domain": "fp",
  "family": "Core FP",
  "def": "Functions that capture and carry the variables of their defining scope.",
  "problem": "Bundle behaviour with the state it needs, enabling callbacks, factories and partial application.",
  "mechanism": "The function value retains references (by value or reference) to free variables from its enclosing scope, kept alive as long as the closure lives.",
  "benefits": [
    "Encapsulate state with behaviour",
    "Enable callbacks & higher-order patterns",
    "Concise factories"
  ],
  "limits": [
    "Lifetime/capture subtleties",
    "Accidental large captures → memory",
    "Reference vs value capture confusion"
  ],
  "failures": [
    "Capturing a loop variable by reference (classic bug)",
    "Reference cycles via captured state"
  ],
  "whenNot": [
    "When a plain function/parameter is clearer"
  ],
  "myths": [
    "\"Closures are free\" — captures allocate and can extend object lifetimes"
  ],
