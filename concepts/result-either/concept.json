  "id": "result-either",
  "name": "Result / Either",
  "type": "Functional abstraction",
  "secondary": [
    "Error-handling technique",
    "Type-system technique"
  ],
  "domain": "fp",
  "family": "Effect type",
  "def": "A type encoding success (Ok/Right) or failure (Err/Left) with an explicit error value.",
  "problem": "Make fallible computations explicit and composable without exceptions or sentinel error codes.",
  "mechanism": "A sum type Ok(T) | Err(E); chains propagate failures via map/and_then or the ?-operator, forcing callers to handle errors.",
  "benefits": [
    "Errors are visible in signatures",
    "Composable error pipelines",
    "No hidden control-flow jumps"
  ],
  "limits": [
    "Verbose without sugar (e.g. ?-operator)",
    "Error-type design/conversion overhead",
    "Not for truly exceptional/unrecoverable faults"
  ],
  "failures": [
    "Swallowing errors with unwrap/expect",
    "Stringly-typed errors losing structure"
  ],
  "whenNot": [
    "Unrecoverable invariant violations (panic/abort)",
    "Deep call stacks where exceptions are cleaner (debatable, contextual)"
  ],
  "myths": [
    "\"Result is the same as exceptions\" — semantics, cost and visibility differ"
  ],
  "use": "Direct",
  "sectors": [
    "Systems",
    "Backends",
    "Anywhere errors are expected"
  ],
