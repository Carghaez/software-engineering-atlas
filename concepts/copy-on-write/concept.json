{
  "$schema": "../../schema/concept.schema.json",
  "id": "copy-on-write",
  "name": "Copy-on-Write (CoW)",
  "type": "Resource-management technique",
  "secondary": [
    "Performance-optimisation technique"
  ],
  "domain": "memory",
  "family": "Lazy copy",
  "def": "Sharing data between copies until one mutates, at which point it is duplicated.",
  "problem": "Make copies cheap (O(1) share) while preserving value semantics for rare mutations.",
  "mechanism": "Copies share a refcounted buffer; on the first write, the writer makes a private copy (if shared) before mutating.",
  "benefits": [
    "O(1) copies when reads dominate",
    "Memory savings via sharing",
    "Value semantics preserved"
  ],
  "limits": [
    "Write triggers a full copy (latency spike)",
    "Refcount/atomic overhead",
    "Concurrency hazards (CoW + threads)"
  ],
  "failures": [
    "Thread-safety bugs in CoW under sharing (historic std::string)",
    "Surprise latency on first write"
  ],
  "whenNot": [
    "Write-heavy data; predictable latency needs"
  ],
  "myths": [
    "\"CoW makes everything cheap\" — the first write pays the full copy"
  ],
  "use": "Both",
  "sectors": [
    "OS (fork)",
    "Strings/buffers",
    "Filesystems (ZFS/Btrfs)"
  ],
  "complexity": null,
  "related": [
    "reference-counting",
    "immutability",
    "persistent-data-structures"
  ],
