  "mechanism": "Recursively splits the DFT into even/odd subproblems (Cooley-Tukey), reusing symmetry of roots of unity to combine in linear time.",
  "benefits": [
    "O(n log n) vs O(n²) naive DFT",
    "Fast convolution / polynomial multiply",
    "Ubiquitous in DSP"
  ],
  "limits": [
    "Best with power-of-two sizes",
    "Floating-point error accumulation",
    "Non-trivial to implement well"
  ],
  "failures": [
    "Numerical instability at large n",
    "Wrong normalisation/scaling conventions"
  ],
