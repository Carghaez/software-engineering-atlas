  "benefits": [
    "O(n log n) worst case, O(1) extra space",
    "No adversarial quadratic case",
    "Used as introsort’s fallback"
  ],
  "limits": [
    "Poor cache locality (sift jumps)",
    "Not stable",
    "Slower in practice than quicksort"
  ],
  "failures": [
    "Comparator inconsistency corrupting the heap"
  ],
  "whenNot": [
    "Stability needed; cache-sensitive hot paths"
