  "family": "Unsupervised ML",
  "def": "Partitions points into k clusters by alternately assigning points to nearest centroids and recomputing centroids.",
  "problem": "Find natural groupings in unlabelled data with a simple, scalable method.",
  "mechanism": "Initialise k centroids (k-means++), assign each point to its nearest, recompute centroids as cluster means, repeat to convergence.",
  "benefits": [
    "Simple, fast, scalable",
    "Works well on globular clusters",
    "k-means++ improves init"
  ],
  "limits": [
    "Must choose k upfront",
    "Sensitive to init and outliers",
    "Assumes spherical, similar-size clusters"
  ],
  "failures": [
    "Bad init → poor local optimum",
    "Forcing k clusters on non-clustered data"
  ],
  "whenNot": [
    "Non-convex / varying-density clusters (use DBSCAN)",
    "Unknown, hard-to-estimate k"
  ],
  "myths": [
    "\"k-means finds the best clustering\" — it finds a local optimum dependent on init"
  ],
