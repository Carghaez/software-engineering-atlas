  "id": "defensive-copying",
  "name": "Defensive Copying",
  "type": "Defensive-programming practice",
  "secondary": [
    "Resource-management technique"
  ],
  "domain": "reliability",
  "family": "Encapsulation",
  "def": "Copying mutable inputs/outputs at trust boundaries so callers cannot mutate internal state.",
  "problem": "Protect an object’s invariants from external code holding aliases to its mutable internals.",
  "mechanism": "Copy mutable arguments on the way in and mutable fields on the way out, so no shared alias can corrupt internal state after validation.",
  "benefits": [
    "Preserves invariants against aliasing",
    "Critical for thread-safety and security boundaries",
    "Predictable behaviour"
  ],
  "limits": [
    "Allocation/copy cost",
    "Deep vs shallow copy subtleties",
    "Redundant where data is already immutable"
  ],
  "failures": [
    "Shallow copy leaving nested mutability exposed",
    "Copy storms in hot paths"
  ],
  "whenNot": [
    "Immutable data (no copy needed)",
    "Performance-critical paths with trusted callers"
  ],
  "myths": [
    "\"Always copy defensively\" — immutability makes it unnecessary"
  ],
  "use": "Direct",
  "sectors": [
    "Libraries",
    "Security boundaries",
    "Concurrency"
  ],
