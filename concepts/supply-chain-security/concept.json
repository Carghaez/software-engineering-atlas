  "family": "Build integrity",
  "def": "Securing the dependencies, build pipeline and artifacts that go into shipped software.",
  "problem": "Prevent compromise via third-party dependencies, build systems or tampered artifacts.",
  "mechanism": "Pin and audit dependencies, generate SBOMs, sign artifacts, use reproducible builds and verify provenance (e.g. SLSA).",
  "benefits": [
    "Detects/limits compromised dependencies",
    "Provenance and integrity guarantees",
    "Faster incident response (SBOM)"
  ],
  "limits": [
    "Tooling/process overhead",
    "Transitive dependency sprawl",
    "Reproducible builds are hard to achieve"
  ],
  "failures": [
    "Unpinned deps pulling malicious updates",
    "Unsigned artifacts; build server compromise"
  ],
  "whenNot": [
    "Never skip; depth scales with exposure"
  ],
  "myths": [
    "\"My code is secure so I’m safe\" — dependencies and build are the bigger attack surface today"
  ],
