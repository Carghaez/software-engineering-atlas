  "domain": "hardware",
  "family": "Locality optimisation",
  "def": "Loading data into cache before it is needed to hide memory latency.",
  "problem": "Avoid CPU stalls waiting on memory by overlapping fetch with computation.",
  "mechanism": "Hardware prefetchers detect strided access; software prefetch intrinsics or restructured access patterns hint upcoming loads ahead of use.",
  "benefits": [
    "Hides DRAM latency on predictable access",
    "Big wins on streaming/strided loops",
    "Cheap when the pattern is regular"
  ],
  "limits": [
    "Useless/harmful on random access",
    "Manual prefetch is easy to get wrong",
    "Cache pollution if over-prefetched"
  ],
  "failures": [
    "Prefetching wrong addresses → wasted bandwidth",
    "Pointer-chasing defeats hardware prefetch"
  ],
  "whenNot": [
    "Irregular/pointer-heavy access patterns"
  ],
  "myths": [
    "\"Manual prefetch always helps\" — the hardware prefetcher often does better; manual can hurt"
  ],
  "use": "Both",
