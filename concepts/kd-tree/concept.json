  "domain": "structures",
  "family": "Spatial",
  "def": "A binary space-partitioning tree that splits k-dimensional points along alternating axes.",
  "problem": "Nearest-neighbour and range search over low-to-moderate-dimensional points.",
  "mechanism": "Each level splits on one axis at the median; search prunes subtrees that cannot contain a closer point.",
  "benefits": [
    "O(log n) average NN search in low dimensions",
    "Simple, memory-light",
    "Good for static point sets"
  ],
  "limits": [
    "Degrades to O(n) in high dimensions (curse of dimensionality)",
    "Rebalancing after inserts is awkward",
    "Poor for dynamic data"
  ],
  "failures": [
    "Using it beyond ~10–20 dims (no better than brute force)",
    "Skewed trees from non-median splits"
  ],
  "whenNot": [
    "High-dimensional data (use LSH/ANN)",
    "Heavily dynamic point sets"
  ],
  "myths": [
    "\"k-d trees scale to any dimension\" — they collapse in high dimensions"
  ],
