  "domain": "fp",
  "family": "Effect system",
  "def": "A mechanism to declare effectful operations and interpret them later with installable handlers.",
  "problem": "Compose effects (state, exceptions, async, generators) more flexibly than monad transformers.",
  "mechanism": "Code performs abstract effect operations; a surrounding handler resumes the computation (via delimited continuations), choosing how each effect behaves.",
  "benefits": [
    "Compose effects without transformer stacks",
    "Separate effect use from interpretation",
    "Powers async/generators uniformly"
  ],
  "limits": [
    "Cutting-edge; limited language support",
    "Continuation cost & mental model",
    "Tooling immature"
  ],
  "failures": [
    "Unhandled effects at runtime",
    "Surprising control flow via resumes"
  ],
  "whenNot": [
    "Mainstream production code today (mostly research/experimental)"
  ],
  "myths": [
    "\"Algebraic effects are just exceptions\" — handlers can resume, not only abort"
  ],
