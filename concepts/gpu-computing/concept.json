  "domain": "hardware",
  "family": "Massive data parallelism",
  "def": "Offloading massively-parallel work to GPUs that run thousands of threads in SIMT lockstep groups.",
  "problem": "Achieve throughput far beyond CPUs on highly-parallel, arithmetic-dense workloads.",
  "mechanism": "Threads grouped into warps/wavefronts execute the same instruction; kernels run over huge grids. Performance hinges on occupancy, coalesced memory access and minimal divergence.",
  "benefits": [
    "Orders-of-magnitude throughput on parallel kernels",
    "High memory bandwidth",
    "Mature for ML/graphics/HPC"
  ],
  "limits": [
    "Host↔device transfer latency/cost",
    "Branch divergence serialises a warp",
    "Hard to program; limited per-thread resources"
  ],
  "failures": [
    "Transfer overhead dwarfing compute on small jobs",
    "Uncoalesced access / divergence destroying throughput"
  ],
  "whenNot": [
    "Small/irregular/latency-sensitive work",
    "Heavy branching or pointer-chasing"
  ],
  "myths": [
    "\"GPU is just a faster CPU\" — SIMT, memory model and divergence change everything"
  ],
  "use": "Both",
