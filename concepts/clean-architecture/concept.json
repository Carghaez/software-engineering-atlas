  "domain": "architecture",
  "family": "Layering",
  "def": "Concentric layers with dependencies pointing inward toward framework-independent domain entities.",
  "problem": "Protect core business rules from frameworks, UI and databases so they can evolve independently.",
  "mechanism": "Entities and use-cases at the centre; outer rings (adapters, frameworks) depend inward via interfaces (dependency rule). I/O is pushed to the edges.",
  "benefits": [
    "Framework/DB independence of core",
    "Highly testable domain",
    "Long-lived, adaptable systems"
  ],
  "limits": [
    "Significant boilerplate/mapping",
    "Overkill for simple apps",
    "Learning curve"
  ],
  "failures": [
    "Mapping fatigue across rings",
    "Domain leaking framework types"
  ],
  "whenNot": [
    "CRUD apps, prototypes, short-lived tools"
  ],
  "myths": [
    "\"Clean Architecture is always better\" — its ceremony rarely pays off for simple systems"
  ],
