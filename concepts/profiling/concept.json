    "Reveals real bottlenecks (often surprising)",
    "Prevents wasted micro-optimisation",
    "Sampling has low overhead"
  ],
  "limits": [
    "Observer effect distorts measurements",
    "Instrumentation overhead can mislead",
    "Production vs dev profile mismatch"
  ],
  "failures": [
    "Optimising what isn’t the bottleneck",
    "Profiling unrepresentative workloads"
  ],
  "whenNot": [
    "Before there is a measured performance problem (premature optimisation)"
