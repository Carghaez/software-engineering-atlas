  "id": "liskov-substitution",
  "name": "Liskov Substitution Principle",
  "type": "Design principle",
  "secondary": [
    "Type-system technique"
  ],
  "domain": "architecture",
  "family": "SOLID",
  "def": "Subtypes must be usable anywhere their base type is, without breaking expectations.",
  "problem": "Prevent inheritance/subtyping that silently violates the contract callers rely on.",
  "mechanism": "Subtypes must not strengthen preconditions or weaken postconditions/invariants; behavioural compatibility, not just signature compatibility.",
  "benefits": [
    "Safe polymorphism",
    "Reliable contracts across hierarchies",
    "Reasoning about base type holds"
  ],
  "limits": [
    "Behavioural compatibility is subtle",
    "Classic violations (Square extends Rectangle)",
    "Hard to enforce mechanically"
  ],
  "failures": [
    "Subclass throwing on inherited operations",
    "Overrides that change semantics"
  ],
  "whenNot": [
    "When composition fits better than inheritance"
  ],
  "myths": [
    "\"If it compiles, LSP holds\" — it is about behaviour, not just types"
  ],
  "use": "Direct",
  "sectors": [
    "OO systems",
    "Libraries"
  ],
