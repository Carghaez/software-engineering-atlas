  "domain": "fp",
  "family": "Compositional abstraction",
  "def": "Constructs that stack multiple monadic effects (state + error + IO) into one combined monad.",
  "problem": "Use several effects together when each is a separate monad that does not compose automatically.",
  "mechanism": "A transformer (e.g. StateT, ReaderT) wraps an inner monad, threading both effects; a stack of transformers yields one monad with all the effects.",
  "benefits": [
    "Compose multiple effects",
    "Reuse standard effect building blocks",
    "Type-tracked effects"
  ],
  "limits": [
    "Stacks get unwieldy and slow",
    "Steep learning curve",
    "Lift boilerplate; HKT-dependent"
  ],
  "failures": [
    "Deep stacks becoming unreadable",
    "Performance overhead per layer"
  ],
