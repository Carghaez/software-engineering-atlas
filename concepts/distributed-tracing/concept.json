  "id": "distributed-tracing",
  "name": "Distributed Tracing",
  "type": "Debugging or observability technique",
  "secondary": [],
  "domain": "observability",
  "family": "Telemetry",
  "def": "Following a single request across many services via propagated trace and span IDs.",
  "problem": "Diagnose latency and failures in distributed systems where one request spans many services.",
  "mechanism": "A trace context (trace/span IDs) propagates across service calls; each service emits timed spans assembled into an end-to-end tree (e.g. OpenTelemetry).",
  "benefits": [
    "End-to-end latency breakdown",
    "Pinpoints the slow/failing hop",
    "Reveals service dependencies"
  ],
  "limits": [
    "Instrumentation effort across services",
    "Sampling vs cost/volume trade-off",
    "Context propagation gaps break traces"
  ],
  "failures": [
    "Broken context propagation → orphan spans",
    "100% sampling overwhelming storage/cost"
  ],
  "whenNot": [
    "Monoliths/simple apps (profiling/logs suffice)"
  ],
  "myths": [
    "\"Tracing replaces logs/metrics\" — they are complementary observability pillars"
  ],
  "use": "Indirect",
